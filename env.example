# Match this exactly in your Facebook App webhook settings (can reuse the same one as Instagram)
VERIFY_TOKEN=scenorium_token

# From Facebook Developer App → Page Access Token (NOT the Instagram token)
FACEBOOK_PAGE_ACCESS_TOKEN=your_facebook_page_access_token_here

# Your Groq API key (can reuse the same one as Instagram)
GROQ_API_KEY=your_groq_api_key_here

PORT=3000
